# Production Environment Variables
# These variables are used during production build and deployment

# GitHub Pages Configuration
REACT_APP_GITHUB_PAGES=true
PUBLIC_URL=/portfolio/

# API Endpoints
REACT_APP_API_URL=https://brenoASantana.github.io/portfolio/api

# Feature Flags
REACT_APP_ENABLE_ANALYTICS=true
REACT_APP_ENABLE_ERROR_REPORTING=true

# Monitoring (optional - add your own)
# REACT_APP_SENTRY_DSN=your_sentry_dsn_here
